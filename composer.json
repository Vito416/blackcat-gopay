{
  "name": "blackcatacademy/blackcat-gopay",
  "description": "GoPay payments adapter (DB-backed) for the BlackCat ecosystem.",
  "type": "library",
  "license": "proprietary",
  "require": {
    "php": "^8.3",
    "ext-curl": "*",
    "ext-json": "*",
    "ext-pdo": "*",
    "psr/log": "^3.0",
    "psr/simple-cache": "^3.0",
    "blackcatacademy/blackcat-core": "dev-dev",
    "blackcatacademy/blackcat-database": "dev-dev"
  },
  "repositories": [
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-core"
    },
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-config"
    },
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-database"
    },
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-database-crypto"
    },
    {
      "type": "git",
      "url": "https://github.com/blackcatacademy/blackcat-crypto"
    }
  ],
  "autoload": {
    "psr-4": {
      "BlackCat\\GoPay\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "BlackCat\\GoPay\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "phpstan/phpstan": "^1.11"
  },
  "minimum-stability": "dev",
  "prefer-stable": true,
  "support": {
    "docs": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/BFNL-1.0.md",
    "source": "https://github.com/Vito416/blackcat-gopay"
  },
  "extra": {
    "blackcat-license": "BFNL-1.0",
    "blackcat-covered-system-notice": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/LICENSING_SYSTEM_NOTICE.md",
    "blackcat-founder-fee-policy": "https://github.com/Vito416/blackcat-darkmesh-ao/blob/main/docs/FEE_POLICY.md"
  }
}
